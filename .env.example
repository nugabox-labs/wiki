# Notion integration token (Internal Integration Secret)
NOTION_TOKEN=

# DEV-WIKI 데이터베이스 ID (URL의 32자리 하이픈 없는 ID 또는 하이픈 포함 UUID)
NOTION_DB_ID=

# 접속 포트 (선택, 개발/운영 모두 기본값 1729로 통일 — 동시에 띄우지 않는 걸 전제)
# DEV_PORT=1729
# PROD_PORT=1729

# 운영 모드에서 notion-sync + hwaro build를 반복하는 주기(초). 기본 900(15분).
# SYNC_INTERVAL_SECONDS=900
